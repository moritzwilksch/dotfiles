{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "pixi lock",
      "pixi install"
    ],
    "filesystem": {
      "allowWrite": [
        "//tmp/claude",
        "~/.cache",
        "~/Library/Caches/"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "conda.anaconda.org",
        "jfrog.io"
      ]
    }
  },
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_CONFIG_FILE": "{{ .chezmoi.homeDir }}/.claude/aws.config",
    "AWS_ENDPOINT_URL": "",
    "AWS_PROFILE": "moritz-personal",
    "AWS_REGION": "eu-central-1"
  },
  "attribution": {
    "commit": "",
    "pr": "Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view *)",
      "Bash(git *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue view *)",
      "Bash(pixi run pre-commit *)",
      "Bash(pixi run lefthook *)",
      "Bash(pixi run lefthook-run *)",
      "Bash(pixi run lint *)",
      "Bash(pixi run test *)",
      "Bash(pixi install *)",
      "Bash(pixi lock *)",
      "WebFetch"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "eu.anthropic.claude-opus-4-7",
  "hooks": {
    "Stop": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/qc-script-claude-notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/qc-script-claude-notification"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium"
}
