{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "pixi lock",
      "pixi install"
    ],
    "filesystem": {
      "allowWrite": [
        "//tmp/claude",
        "~/.cache"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com"
      ]
    }
  },
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_CONFIG_FILE": "{{ .chezmoi.homeDir }}/.claude/aws.config",
    "AWS_PROFILE": "moritz-personal",
    "AWS_REGION": "eu-central-1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "eu.anthropic.claude-opus-4-6-v1[1m]"
  },
  "attribution": {
    "commit": "",
    "pr": "Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue view *)",
      "Bash(pixi run pre-commit *)",
      "Bash(pixi run lefthook *)",
      "Bash(pixi run lefthook-run *)",
      "Bash(pixi run lint *)",
      "Bash(pixi run test *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "modelOverrides": {
    "claude-opus-4-6": "eu.anthropic.claude-opus-4-6-v1"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.pixi/bin/qc-script-sound-microwave-ding"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.pixi/bin/qc-script-sound-doorbell"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium"
}
