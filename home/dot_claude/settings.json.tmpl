{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_CONFIG_FILE": "{{ .chezmoi.homeDir }}/.claude/aws.config",
    "AWS_ENDPOINT_URL": "",
    "AWS_PROFILE": "moritz-personal",
    "AWS_REGION": "eu-central-1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto",
    "ask": [
      "Bash(git push*)",
      "Read(**/*.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.aws/**)",
      "Read(**/.aws/**)",
      "Read(~/.claude/aws.config)",
      "Read(~/.git-credentials)",
      "Read(**/.git-credentials)",
      "Read(**/credentials)",
      "Read(**/.netrc)",
      "Read(~/.ssh/**)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "Stop": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/qc-script-claude-notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/qc-script-claude-notification"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {},
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "tui": "fullscreen"
}
