{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "title_bar": {
    "show_branch_status_icon": true
  },
  "tab_bar": {
    "show": false
  },
  "document_symbols": "on",
  "ui_font_weight": 500.0,
  "file_finder": {
    "include_ignored": "smart",
  },
  "inlay_hints": {
    "show_value_hints": false,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "icon_theme": "Material Icon Theme",
  "sticky_scroll": {
    "enabled": true,
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "terminal": {
    "shell": {
      "program": "/opt/homebrew/bin/fish",
    },
    "dock": "bottom",
    "button": true,
  },
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff"],
      "format_on_save": "off",
    },
  },
  "base_keymap": "VSCode",
  "theme": "Moritz One Dark",
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_size": 13.0,
  "buffer_font_weight": 600.0,
  "ui_font_size": 15.0,
  "autosave": "on_focus_change",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
  },
  "relative_line_numbers": "enabled",
}
