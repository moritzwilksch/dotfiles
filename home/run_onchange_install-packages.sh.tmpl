#!/bin/bash
# packages: neovim font-jetbrains-mono-nerd-font git htop wget curl make gcc
{{ if eq .chezmoi.os "windows" -}}
exit 0
{{ end -}}

set -u

log()  { printf "\033[1;34m[PACKAGES]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[WARN]\033[0m %s\n" "$*"; }

{{ if eq .chezmoi.os "darwin" -}}
if ! command -v brew >/dev/null 2>&1; then
    warn "Homebrew not found. Install it first: https://brew.sh"
    exit 1
fi

log "Installing packages via Homebrew..."
brew install neovim font-jetbrains-mono-nerd-font || warn "Some brew packages may have failed"

{{ else -}}
# Linux: detect package manager
if command -v sudo >/dev/null 2>&1; then
    SUDO="sudo"
else
    SUDO=""
fi

PKG_MGR=""
if command -v apt-get >/dev/null 2>&1; then
    PKG_MGR="apt"
elif command -v dnf >/dev/null 2>&1; then
    PKG_MGR="dnf"
elif command -v yum >/dev/null 2>&1; then
    PKG_MGR="yum"
elif command -v zypper >/dev/null 2>&1; then
    PKG_MGR="zypper"
elif command -v apk >/dev/null 2>&1; then
    PKG_MGR="apk"
fi

log "Detected package manager: ${PKG_MGR:-none}"

pkg_install() {
    for p in "$@"; do
        case "$PKG_MGR" in
            apt)    ($SUDO apt-get install -y "$p") >/dev/null 2>&1 || warn "apt failed for $p" ;;
            dnf)    ($SUDO dnf install -y "$p") >/dev/null 2>&1 || warn "dnf failed for $p" ;;
            yum)    ($SUDO yum install -y "$p") >/dev/null 2>&1 || warn "yum failed for $p" ;;
            zypper) ($SUDO zypper -n install --no-recommends "$p") >/dev/null 2>&1 || warn "zypper failed for $p" ;;
            apk)    ($SUDO apk add --no-cache "$p") >/dev/null 2>&1 || warn "apk failed for $p" ;;
            *)      warn "No package manager to install $p" ;;
        esac
    done
}

if [ -z "$PKG_MGR" ]; then
    warn "No package manager detected. Skipping system packages."
    exit 0
fi

# Update package index
case "$PKG_MGR" in
    apt)    $SUDO apt-get update -y >/dev/null 2>&1 ;;
    dnf)    $SUDO dnf -y makecache >/dev/null 2>&1 ;;
    yum)    $SUDO yum -y makecache fast >/dev/null 2>&1 ;;
    zypper) $SUDO zypper -n refresh >/dev/null 2>&1 ;;
    apk)    $SUDO apk update >/dev/null 2>&1 ;;
esac

# Enable EPEL on RPM distros
case "$PKG_MGR" in
    dnf|yum)
        if [ -f /etc/amazon-linux-release ]; then
            # Amazon Linux 2023: EPEL not available, skip
            true
        elif [ -f /etc/system-release ] && grep -qi "Amazon Linux" /etc/system-release; then
            # Amazon Linux 2: use amazon-linux-extras
            command -v amazon-linux-extras >/dev/null 2>&1 && ($SUDO amazon-linux-extras enable epel 2>/dev/null || true)
        else
            pkg_install epel-release
        fi
        ;;
esac

log "Installing base packages..."
pkg_install git htop wget curl make gcc

# Neovim: try package manager first, fallback to tarball
log "Installing Neovim..."
pkg_install neovim

if ! command -v nvim >/dev/null 2>&1; then
    ARCH="$(uname -m)"
    if [ "$ARCH" = "x86_64" ] || [ "$ARCH" = "amd64" ]; then
        TMP_DIR="$(mktemp -d)"
        log "Downloading Neovim x86_64 tarball..."
        if curl -fsSL -o "$TMP_DIR/nvim-linux-x86_64.tar.gz" https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz; then
            tar -xzf "$TMP_DIR/nvim-linux-x86_64.tar.gz" -C "$TMP_DIR"
            $SUDO rm -rf /usr/local/nvim 2>/dev/null || true
            $SUDO mv "$TMP_DIR/nvim-linux-x86_64" /usr/local/nvim
            $SUDO ln -sf /usr/local/nvim/bin/nvim /usr/local/bin/nvim
            log "Neovim installed from tarball."
        else
            warn "Failed to download Neovim tarball."
        fi
        rm -rf "$TMP_DIR"
    else
        warn "Neovim tarball fallback is x86_64 only (arch: $ARCH)."
    fi
fi

# Clone nvim config
mkdir -p "$HOME/.config"
if [ -d "$HOME/.config/nvim/.git" ]; then
    (cd "$HOME/.config/nvim" && git pull --ff-only >/dev/null 2>&1) || warn "Failed to update nvim config."
else
    (cd "$HOME/.config" && git clone https://github.com/moritzwilksch/nvim.git >/dev/null 2>&1) || warn "Failed to clone nvim config."
fi
{{ end -}}

log "Package installation complete."
